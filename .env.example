# ============================================================================
# Engram v5.8 -- Cognitive Memory Server
# Copy to .env and configure
# ============================================================================

# --- Server ---
ENGRAM_PORT=4200                     # Server port (default: 4200)
ENGRAM_HOST=0.0.0.0                  # Bind address (default: 0.0.0.0)
ENGRAM_DATA_DIR=                     # Data directory (default: ./data)
ENGRAM_LOG_LEVEL=info                # debug | info | warn | error | none

# --- Security ---
ENGRAM_OPEN_ACCESS=0                 # 1 = no auth required (dev only!)
ENGRAM_GUI_PASSWORD=                 # Required unless ENGRAM_OPEN_ACCESS=1
ENGRAM_HMAC_SECRET=                  # HMAC secret for cookies (auto-generated if empty)
ENGRAM_CORS_ORIGIN=                  # Optional allowed origin, e.g. https://engram.example.com
ENGRAM_ALLOWED_IPS=                  # Comma-separated IP allowlist (empty = allow all)
ENGRAM_MAX_BODY_SIZE=1048576         # Max request body in bytes (default: 1MB)
ENGRAM_MAX_CONTENT_SIZE=102400       # Max memory content in bytes (default: 100KB)
ENGRAM_OPEN_RATE_LIMIT=120           # Requests/minute per IP in OPEN_ACCESS mode

# --- Embedding Provider ---
# Provider: "local" = ONNX BGE-large (default, 1024-dim, no API calls)
#           "google" = Google AI Studio (768-dim, requires GOOGLE_API_KEY)
#           "vertex" = Vertex AI (768-dim, requires service account)
ENGRAM_EMBEDDING_PROVIDER=local
# ENGRAM_EMBEDDING_MODEL=            # Auto-set per provider (local: BAAI/bge-large-en-v1.5, google/vertex: text-embedding-005)
# ENGRAM_EMBEDDING_DIM=              # Auto-set per provider (local: 1024, google/vertex: 768)
# ENGRAM_EMBEDDING_FP32=0            # 1 = use full-precision ONNX model instead of quantized (local only)

# --- Google Cloud / Vertex AI ---
# Required only when ENGRAM_EMBEDDING_PROVIDER=google or vertex
# GOOGLE_API_KEY=                    # Google AI Studio API key (falls back to LLM_API_KEY)
# GOOGLE_CLOUD_PROJECT=              # GCP project ID (vertex only)
# GOOGLE_CLOUD_LOCATION=us-central1  # GCP region (vertex only)
# GOOGLE_APPLICATION_CREDENTIALS=    # Path to service account JSON (vertex only)

# --- LLM (for fact extraction, consolidation, reflections) ---
# Supports: Anthropic, MiniMax, Gemini, Groq, DeepSeek, OpenAI, Ollama, LiteLLM, vLLM
LLM_URL=http://127.0.0.1:4100/v1/chat/completions
LLM_API_KEY=                         # Required for intelligent features
LLM_MODEL=gemini-2.5-flash           # Any OpenAI-compatible model

# --- LLM Provider Strategy ---
# LLM_STRATEGY=fallback              # fallback = try primary, then fallbacks on error (default)
#                                     # round-robin = rotate between all providers each call

# --- Additional LLM Providers (for fallback chain or round-robin) ---
# Supports up to 10 providers. Uses LLM_PROVIDER_N_URL/KEY/MODEL/NAME format.
# Provider 1 is always the primary (LLM_URL/LLM_API_KEY/LLM_MODEL).
#
# LLM_PROVIDER_2_URL=http://127.0.0.1:4100/v1/chat/completions
# LLM_PROVIDER_2_MODEL=claude-sonnet-4-20250514
# LLM_PROVIDER_2_NAME=copilot
#
# LLM_PROVIDER_3_URL=https://api.groq.com/openai/v1/chat/completions
# LLM_PROVIDER_3_KEY=gsk_...
# LLM_PROVIDER_3_MODEL=llama-3.3-70b-versatile
# LLM_PROVIDER_3_NAME=groq
#
# LLM_PROVIDER_4_URL=http://127.0.0.1:4100/v1/chat/completions
# LLM_PROVIDER_4_MODEL=claude-opus-4-20250514
# LLM_PROVIDER_4_NAME=anthropic
#
# LLM_PROVIDER_5_URL=https://api.deepseek.com/v1/chat/completions
# LLM_PROVIDER_5_KEY=sk-...
# LLM_PROVIDER_5_MODEL=deepseek-chat
# LLM_PROVIDER_5_NAME=deepseek
#
# Legacy format (LLM_FALLBACK1_URL/KEY/MODEL) still works if no LLM_PROVIDER_N vars are set.

# --- Provider examples ---
# Gemini:  LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# MiniMax: LLM_URL=https://api.minimax.io/v1/chat/completions  LLM_MODEL=MiniMax-M2.5
# Groq:    LLM_URL=https://api.groq.com/openai/v1/chat/completions
# Anthropic: LLM_URL=https://api.anthropic.com/v1/messages  (uses native format)

# --- LLM Reranker (uses LLM for search result re-ranking) ---
ENGRAM_RERANKER=1                    # 0 to disable LLM-based reranking (also accepts: RERANKER=)
ENGRAM_RERANKER_TOP_K=12             # Rerank top K candidates (also accepts: RERANKER_TOP_K=)

# --- Cross-Encoder Reranker (ONNX BGE-reranker-base, runs locally) ---
ENGRAM_CROSS_ENCODER=1               # 0 to disable; auto-downloads ~337MB model on first use
# ENGRAM_RERANKER_FP32=0             # 1 = use full-precision model instead of quantized INT8
# ENGRAM_RERANKER_MAX_SEQ=512        # Max token sequence length for cross-encoder

# --- Search Tuning ---
ENGRAM_SEARCH_MIN_SCORE=0.58         # Minimum score threshold for search results
# ENGRAM_SEARCH_FACT_VECTOR_FLOOR=0.22
# ENGRAM_SEARCH_PREFERENCE_VECTOR_FLOOR=0.12
# ENGRAM_SEARCH_REASONING_VECTOR_FLOOR=0.10
# ENGRAM_SEARCH_GENERALIZATION_VECTOR_FLOOR=0.12
# ENGRAM_SEARCH_PERSONALITY_MIN_SCORE=0.30

# --- Feature Flags (all enabled by default, set to 0 to disable) ---
# ENGRAM_CAUSAL_CHAINS=1             # Causal link detection between memories
# ENGRAM_PREDICTIVE_RECALL=1         # Temporal access pattern prediction
# ENGRAM_EMOTIONAL_VALENCE=1         # Emotional valence analysis
# ENGRAM_RECONSOLIDATION=1           # Memory reconsolidation sweeps
# ENGRAM_ADAPTIVE_IMPORTANCE=1       # Adaptive importance scoring

# --- GUI ---
ENGRAM_HOT_RELOAD=0                  # 1 = reload GUI HTML on every request (dev)

# --- Deprecated (still work, but use the new names) ---
# ZANMEMORY_PORT -> ENGRAM_PORT
# ZANMEMORY_HOST -> ENGRAM_HOST
# MEGAMIND_GUI_PASSWORD -> ENGRAM_GUI_PASSWORD
# RERANKER -> ENGRAM_RERANKER
# RERANKER_TOP_K -> ENGRAM_RERANKER_TOP_K
