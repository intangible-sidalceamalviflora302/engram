{
  "name": "@zanfiel/engram",
  "version": "5.8.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/zanfiel/engram.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    "./sdk": "./sdk/index.ts"
  },
  "files": [
    "server-split.ts",
    "mcp-server.ts",
    "sdk/",
    "src/",
    "sign/",
    "scripts/",
    "engram-gui.html",
    "engram-login.html",
    "Dockerfile",
    "docker-compose.yml",
    ".env.example",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "engram": "./server-split.ts",
    "engram-mcp": "./mcp-server.ts"
  },
  "scripts": {
    "start": "node --experimental-strip-types --env-file=.env server-split.ts",
    "dev": "node --experimental-strip-types --env-file=.env --watch server-split.ts",
    "mcp": "node --experimental-strip-types mcp-server.ts",
    "test": "node --test tests/api.test.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck",
    "backup-drill": "bash scripts/backup-restore-drill.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "html-to-text": "^9.0.5",
    "libsql": "^0.5.22",
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ]
}
